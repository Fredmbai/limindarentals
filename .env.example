# ── Docker Compose environment variables ──────────────────────────────────────
# Copy this file to .env and fill in the values before running docker-compose.
# Never commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=lumindarentals_db
POSTGRES_USER=lumindarentals
POSTGRES_PASSWORD=change_me_strong_password

# ── Django (backend/.env is the main config; these are passed by compose) ─────
# The backend/.env.example file contains the full list of Django settings.
# The variables below are the ones docker-compose injects at container runtime
# to override localhost defaults with Docker service names.
#
# DATABASE_URL and REDIS_URL are set automatically by docker-compose.yml
# using the POSTGRES_* values above — you do not need to set them here.
