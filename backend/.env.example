# ── Core ─────────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/lumindarentals_db

# ── M-Pesa (Daraja) ───────────────────────────────────────────────────────────
# Get from developer.safaricom.co.ke — use production keys, not sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback/

# ── Paystack ──────────────────────────────────────────────────────────────────
# Use live keys from dashboard.paystack.com → Settings → API Keys
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_SECRET_KEY=sk_live_...

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST_USER=youremail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password   # 16-char App Password, not your Gmail password
DEFAULT_FROM_EMAIL=NestRentals <youremail@gmail.com>

# ── Africa's Talking (SMS) ────────────────────────────────────────────────────
# Use live credentials from africastalking.com
AT_USERNAME=nestrentals
AT_API_KEY=
AT_SENDER_ID=NestRent

# ── Platform fee ─────────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENTAGE=0.3

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate once: python manage.py generate_vapid_keys  (never regenerate — breaks existing subscriptions)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=youremail@gmail.com
